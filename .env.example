# SolarReach — example environment file. Copy to `.env` and fill in.
# DO NOT commit `.env`. `.env.example` is the canonical reference.

# ------------------------------------------------------------------ Mongo
# Application user URI. Note ?authSource=admin — the user lives in admin
# but reads/writes the `solarreach` db. Easy to forget; breaks silently.
MONGO_URI=mongodb://solarreach_app:change-me-in-prod@localhost:27017/solarreach?authSource=admin

# Used by docker-compose to bootstrap the root user on first boot.
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=change-me-on-first-run
SOLARREACH_DB_USER=solarreach_app
SOLARREACH_DB_PASSWORD=change-me-in-prod

# ----------------------------------------------------------- Adapter mode
# 'mock' (default) uses deterministic free adapters; 'real' goes to live APIs.
SOLARREACH_ADAPTER_MODE=mock

# Per-adapter overrides (uppercase name in the slot):
# SOLARREACH_GEOCODING_MODE=real
# SOLARREACH_PVGIS_MODE=real
# SOLARREACH_SOLAR_MODE=real
# SOLARREACH_IMD_MODE=real
# SOLARREACH_CH_MODE=real
# SOLARREACH_WEATHER_MODE=real

# --------------------------------------------------- Outbound safety gate
# When false, voice + email send paths refuse to dispatch.
# Flip to `true` ONLY for the live demo window.
SOLARREACH_LIVE_OUTBOUND=false

# ----------------------------------------------------- API keys (real only)
# Google API key — must have Application Restriction = None for server-side
# calls (referrer restriction would 403 with API_KEY_HTTP_REFERRER_BLOCKED).
GOOGLE_API_KEY=

# Companies House key. Used via HTTP Basic Auth (key as username, no password).
COMPANIES_HOUSE_API_KEY=

# Hunter.io for email enrichment (post-gate only).
HUNTER_API_KEY=

# Voyage AI for embeddings (1024-dim 'voyage-3').
VOYAGE_API_KEY=

# Anthropic for codex / outreach generation. Also used by the Lead Researcher
# agent — required when running `make agent`.
ANTHROPIC_API_KEY=

# ElevenLabs for voice agent (Project 5).
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# ------------------------------------------------------------ Agent runtime
# Default model the Lead Researcher uses. Format is provider:model_id.
SOLARREACH_AGENT_MODEL=anthropic:claude-sonnet-4-6

# Hard cap on agent recursion depth — protects against runaway loops.
SOLARREACH_AGENT_RECURSION_LIMIT=60

# LangSmith tracing (optional but recommended for the demo).
# Get a key from https://smith.langchain.com — turn it on once,
# every agent run shows up as a thread you can replay.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=solarreach
